rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) && 
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "frassa0000@gmail.com" && request.auth.token.email_verified == true));
    }

    // Support Tickets (Audio)
    match /support_tickets/{ticketId} {
      allow read: if isAuthenticated() && (isAdmin() || request.auth.uid != null); // User can read their own if they have the URL
      allow create: if isAuthenticated(); // Allow any authenticated user to upload a ticket
      allow delete: if isAdmin();
    }

    // Mod Files
    match /mods/{modId}/{fileName} {
      allow read: if true; // Publicly downloadable
      allow create, update, delete: if isAdmin();
    }

    // Mod Images
    match /mod_images/{modId}/{fileName} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // User Avatars and Banners
    match /avatars/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    match /banners/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }
  }
}
